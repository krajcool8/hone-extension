{
  "manifest_version": 3,
  "name": "Hone",
  "version": "0.1.0",
  "description": "Coaching for better AI prompts",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": ["https://api.anthropic.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "commands": {
    "trigger-hone": {
      "suggested_key": {
        "default": "Ctrl+Shift+H",
        "mac": "Command+Shift+H"
      },
      "description": "Analyse selected prompt text"
    }
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["overlay.html", "overlay.css", "overlay.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
